{% comment %} ── CUSTOM FOOTER — paste into a Custom Liquid section ── {% endcomment %}

<style>
#cf-{{ section.id }} {
  --cf-bg:     {{ section.settings.bg_color }};
  --cf-bar:    {{ section.settings.bar_color }};
  --cf-text:   {{ section.settings.text_color }};
  --cf-muted:  {{ section.settings.muted_color }};
  --cf-accent: {{ section.settings.accent_color }};
  --cf-border: {{ section.settings.border_color }};
  --cf-ease:   cubic-bezier(.4,0,.2,1);

}
#cf-{{ section.id }}*,
#cf-{{ section.id }}*::before,
#cf-{{ section.id }}*::after { box-sizing: border-box; margin: 0; padding: 0; }

/* TOP BORDER */
#cf-{{ section.id }} {
  border-top: 1px solid var(--cf-border);
}

/* MOBILE overrides */
@media (max-width: 768px) {
}

/* MAIN GRID */
#cf-{{ section.id }} .cf-main {
  background: var(--cf-bg); max-width: 1900px;
  margin: 0 auto; padding: 56px 32px 48px;
  display: grid; grid-template-columns: 1.6fr 1fr 1fr 1.2fr; gap: 48px;
}

/* HEADING */
#cf-{{ section.id }} .cf-h {
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--cf-text);
  margin-bottom: 18px; padding-bottom: 10px;
  border-bottom: 1px solid var(--cf-border);
}

/* BRAND */
#cf-{{ section.id }} .cf-logo-responsive {
  height: auto;
  max-height: 160px;
  width: {{ section.settings.logo_width }}px;
  max-width: 100%;
  object-fit: contain;
  display: block;
  margin-bottom: 16px;
}
#cf-{{ section.id }} .cf-logo-text {
  font-size: 1.45rem; font-weight: 900; letter-spacing: -0.04em;
  color: var(--cf-text); text-decoration: none;
  display: inline-block; margin-bottom: 16px; line-height: 1;
}
#cf-{{ section.id }} .cf-logo-text em { color: var(--cf-accent); font-style: normal; }
#cf-{{ section.id }} .cf-desc {
  font-size: 0.85rem; color: var(--cf-muted); line-height: 1.8; margin-bottom: 22px;
}
#cf-{{ section.id }} .cf-badges { display: flex; flex-wrap: wrap; gap: 7px; }
#cf-{{ section.id }} .cf-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 11px; border: 1px solid var(--cf-border); border-radius: 100px;
  font-size: 0.67rem; font-weight: 600; color: var(--cf-muted); letter-spacing: 0.04em;
}
#cf-{{ section.id }} .cf-badge svg { color: var(--cf-accent); }

/* NAV LINKS */
#cf-{{ section.id }} .cf-links { list-style: none; display: flex; flex-direction: column; gap: 9px; }
#cf-{{ section.id }} .cf-links a {
  color: var(--cf-muted); text-decoration: none; font-size: 0.875rem;
  display: inline-flex; align-items: center; gap: 0;
  transition: color .2s var(--cf-ease), gap .2s var(--cf-ease);
}
#cf-{{ section.id }} .cf-links a::before {
  content: ''; display: inline-block; width: 0; height: 1.5px;
  background: var(--cf-accent); flex-shrink: 0;
  transition: width .2s var(--cf-ease);
}
#cf-{{ section.id }} .cf-links a:hover { color: var(--cf-text); gap: 8px; }
#cf-{{ section.id }} .cf-links a:hover::before { width: 10px; }

/* EMAIL */
#cf-{{ section.id }} .cf-email {
  display: inline-flex; align-items: center; gap: 8px;
  color: var(--cf-muted); font-size: 0.875rem; text-decoration: none;
  margin-bottom: 24px; transition: color .2s; word-break: break-all;
}
#cf-{{ section.id }} .cf-email:hover { color: var(--cf-accent); }
#cf-{{ section.id }} .cf-email svg { color: var(--cf-accent); flex-shrink: 0; }

/* SOCIAL */
#cf-{{ section.id }} .cf-slbl {
  font-size: 0.67rem; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--cf-muted); margin-bottom: 10px; display: block;
}
#cf-{{ section.id }} .cf-social { display: flex; gap: 8px; flex-wrap: wrap; }
#cf-{{ section.id }} .cf-s {
  width: 38px; height: 38px; border-radius: 9px;
  border: 1px solid var(--cf-border);
  display: flex; align-items: center; justify-content: center;
  color: var(--cf-muted); text-decoration: none;
  transition: background .2s, border-color .2s, color .2s, transform .2s;
}
#cf-{{ section.id }} .cf-s:hover {
  background: var(--cf-accent); border-color: var(--cf-accent);
  color: #fff; transform: translateY(-3px);
}

/* BOTTOM BAR */
#cf-{{ section.id }} .cf-sep {
  border: none; border-top: 1px solid var(--cf-border);
  max-width: 1900px; margin: 0 auto 0;
}
#cf-{{ section.id }} .cf-bar { background: var(--cf-bar); }
#cf-{{ section.id }} .cf-bar-in {
  max-width: 1900px; margin: 0 auto; padding: 18px 32px;
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 14px;
}
#cf-{{ section.id }} .cf-copy { font-size: 0.78rem; color: var(--cf-muted); }
#cf-{{ section.id }} .cf-copy strong { color: #ccc; font-weight: 600; }
#cf-{{ section.id }} .cf-br { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
#cf-{{ section.id }} .cf-tagline {
  font-size: 0.74rem; color: var(--cf-muted); font-style: italic;
  display: flex; align-items: center; gap: 5px;
}
#cf-{{ section.id }} .cf-tagline svg { color: var(--cf-accent); }

/* PAYMENT ICONS */
#cf-{{ section.id }} .cf-pay { display: flex; align-items: center; gap: 5px; flex-wrap: wrap; }
#cf-{{ section.id }} .cf-pi {
  background: #1a1a1a; border: 1px solid #272727; border-radius: 5px;
  padding: 4px 8px; display: flex; align-items: center; justify-content: center;
  height: 26px;
}

/* RESPONSIVE */
@media (max-width: 1024px) {
  #cf-{{ section.id }} .cf-main { grid-template-columns: 1fr 1fr; gap: 32px; padding: 44px 24px 36px; }
  #cf-{{ section.id }} .cf-col-brand { grid-column: span 2; }
}

@media (max-width: 600px) {
  #cf-{{ section.id }} .cf-main { grid-template-columns: 1fr; gap: 28px; padding: 36px 20px 28px; }
  #cf-{{ section.id }} .cf-col-brand { grid-column: span 1; }
  #cf-{{ section.id }} .cf-bar-in { flex-direction: column; align-items: flex-start; }
  #cf-{{ section.id }} .cf-trust-inner { padding: 0 20px; }

  /* ── MOBILE LOGO: center + mobile size ── */
  #cf-{{ section.id }} .cf-col-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  #cf-{{ section.id }} .cf-logo-responsive {
    width: {{ section.settings.logo_width_mobile }}px;
    margin-left: auto;
    margin-right: auto;
  }
  #cf-{{ section.id }} .cf-logo-text {
    text-align: center;
    width: 100%;
  }
  #cf-{{ section.id }} .cf-desc {
    text-align: center;
  }
  #cf-{{ section.id }} .cf-badges {
    justify-content: center;
  }
}
</style>

<div id="cf-{{ section.id }}">

  <!-- ─── MAIN COLUMNS ────────────────────────────── -->
  <div class="cf-main">

    <!-- COL 1: BRAND -->
    <div class="cf-col-brand">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 400 }}"
             alt="{{ shop.name }}"
             class="cf-logo-responsive"
             loading="lazy">
      {%- else -%}
        <a href="/" class="cf-logo-text">{{ shop.name }}</a>
      {%- endif -%}

      <p class="cf-desc">{{ section.settings.description }}</p>

      <div class="cf-badges">
        <span class="cf-badge">
          <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M6 1L7.5 4.5L11 5L8.5 7.5L9 11L6 9.5L3 11L3.5 7.5L1 5L4.5 4.5L6 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
          Premium Quality
        </span>
        <span class="cf-badge">
          <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 6L4.5 8.5L10 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Made to Order
        </span>
        <span class="cf-badge">
          <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.2"/><path d="M6 3.5V6L7.5 7.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
          Fast Dispatch
        </span>
      </div>
    </div>

    <!-- COL 2: QUICK LINKS -->
    <div>
      <h3 class="cf-h">{{- section.settings.col2_heading | default: 'Quick Links' -}}</h3>
      {%- if section.settings.quick_menu != blank -%}
        <ul class="cf-links">
          {%- for link in linklists[section.settings.quick_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <!-- COL 3: CUSTOMER INFO -->
    <div>
      <h3 class="cf-h">{{- section.settings.col3_heading | default: 'Customer Info' -}}</h3>
      {%- if section.settings.info_menu != blank -%}
        <ul class="cf-links">
          {%- for link in linklists[section.settings.info_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <!-- COL 4: CONTACT + SOCIAL -->
    <div>
      <h3 class="cf-h">Get in Touch</h3>
      {%- if section.settings.email != blank -%}
        <a href="mailto:{{ section.settings.email }}" class="cf-email">
          <svg width="14" height="14" viewBox="0 0 15 15" fill="none">
            <rect x="1" y="3" width="13" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
            <path d="M1.5 3.5L7.5 8.5L13.5 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
          {{ section.settings.email }}
        </a>
      {%- endif -%}

      {%- if section.settings.show_social -%}
        <span class="cf-slbl">Follow Us</span>
        <div class="cf-social">
          {%- if section.settings.facebook != blank -%}
            <a href="{{ section.settings.facebook }}" class="cf-s" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" class="cf-s" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.email2 != blank -%}
            <a href="mailto:{{ section.settings.email2 }}" class="cf-s" aria-label="Email us">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.x_url != blank -%}
            <a href="{{ section.settings.x_url }}" class="cf-s" target="_blank" rel="noopener" aria-label="X (Twitter)">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

  </div><!-- /cf-main -->

  <hr class="cf-sep">

  <!-- ─── BOTTOM BAR ───────────────────────────────── -->
  <div class="cf-bar">
    <div class="cf-bar-in">
      <p class="cf-copy">
        &copy; {{ 'now' | date: '%Y' }} <strong>{{ shop.name }}</strong>.
        {{ section.settings.copyright | default: 'All rights reserved.' }}
      </p>
      <div class="cf-br">
        {%- if section.settings.tagline != blank -%}
          <span class="cf-tagline">
            <svg width="11" height="11" viewBox="0 0 13 13" fill="none"><path d="M6.5 1.5L8 5L12 5.5L9 8.5L10 12L6.5 10L3 12L4 8.5L1 5.5L5 5L6.5 1.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
            {{ section.settings.tagline }}
          </span>
        {%- endif -%}
        {%- if section.settings.show_payment -%}
          <div class="cf-pay">
            {%- if section.settings.payment_image != blank -%}
              <img src="{{ section.settings.payment_image | image_url: width: 300 }}"
                   alt="Payment methods"
                   style="height:22px;width:auto;object-fit:contain;"
                   loading="lazy">
            {%- else -%}
              <span class="cf-pi" title="Visa">
                <svg width="34" height="11" viewBox="0 0 50 16"><text x="0" y="13" font-family="Arial" font-size="14" font-weight="900" fill="#1A1FEB" letter-spacing="1">VISA</text></svg>
              </span>
              <span class="cf-pi" title="Mastercard">
                <svg width="32" height="20" viewBox="0 0 32 20" fill="none">
                  <circle cx="12" cy="10" r="9" fill="#EB001B"/>
                  <circle cx="20" cy="10" r="9" fill="#F79E1B"/>
                  <path d="M16 3.53A9 9 0 0 1 19.47 10 9 9 0 0 1 16 16.47 9 9 0 0 1 12.53 10 9 9 0 0 1 16 3.53z" fill="#FF5F00"/>
                </svg>
              </span>
              <span class="cf-pi" title="PayPal">
                <svg width="44" height="13" viewBox="0 0 52 14">
                  <text x="0" y="11" font-family="Arial" font-size="11" font-weight="700" fill="#009cde">Pay</text>
                  <text x="22" y="11" font-family="Arial" font-size="11" font-weight="700" fill="#003087">Pal</text>
                </svg>
              </span>
              <span class="cf-pi" title="American Express">
                <svg width="36" height="11" viewBox="0 0 46 13">
                  <text x="0" y="10" font-family="Arial" font-size="10" font-weight="800" fill="#2E77BC" letter-spacing="0.5">AMEX</text>
                </svg>
              </span>
              <span class="cf-pi" title="Apple Pay" style="gap:2px; display:flex; align-items:center;">
                <svg width="11" height="13" viewBox="0 0 14 17" fill="none">
                  <path d="M11.5 4.5C10.5 4.5 9.8 5 9.3 5s-1-.4-1.8-.4C6.1 4.6 4.7 5.5 4 7c-1.4 2.4-.4 6 1 7.9.7.9 1.4 1.9 2.4 1.9.9 0 1.2-.6 2.3-.6s1.3.6 2.3.6 1.6-.9 2.3-1.9c.7-1 .9-2 .9-2.1-.1 0-1.8-.7-1.8-2.6 0-1.7 1.3-2.5 1.4-2.5C14 7.2 12.8 4.5 11.5 4.5z" fill="#aaa"/>
                  <path d="M10.2 2.6C10.7 2 11 1.1 10.8.3 10 .4 9 .9 8.5 1.6c-.5.6-.8 1.5-.7 2.3.9.1 1.8-.4 2.4-1.3z" fill="#aaa"/>
                </svg>
                <svg width="22" height="10" viewBox="0 0 30 12"><text x="0" y="10" font-family="Arial" font-size="10" font-weight="600" fill="#aaa">Pay</text></svg>
              </span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

</div><!-- /cf wrapper -->

{% schema %}
{
  "name": "Custom Footer",
  "tag": "section",
  "class": "shopify-section-custom-footer",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Store logo",
      "info": "Leave blank to show store name as text"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width — Desktop (px)",
      "min": 80,
      "max": 500,
      "step": 10,
      "default": 220
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Logo width — Mobile (px)",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 140,
      "info": "Logo will be centred automatically on mobile screens."
    },
    {
      "type": "header",
      "content": "Brand Column"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Store description",
      "default": "We create beautifully personalised gifts and custom products — made with love, crafted just for you. From custom bottles to keepsakes, every order is unique."
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "text",
      "id": "col2_heading",
      "label": "Column 2 heading",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "quick_menu",
      "label": "Quick Links menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "col3_heading",
      "label": "Column 3 heading",
      "default": "Customer Info"
    },
    {
      "type": "link_list",
      "id": "info_menu",
      "label": "Customer Info menu"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email",
      "default": "hello@yourstore.com"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "text",
      "id": "email2",
      "label": "Second email (shows as mail icon)"
    },
    {
      "type": "url",
      "id": "x_url",
      "label": "X (Twitter) URL"
    },
    {
      "type": "header",
      "content": "Bottom Bar"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright suffix",
      "default": "All rights reserved."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Personalised with love, delivered with care."
    },
    {
      "type": "header",
      "content": "Payment Icons"
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "payment_image",
      "label": "Custom payment icons image",
      "info": "Upload your own payment strip image. Leave blank to use built-in icons."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "bar_color",
      "label": "Bottom bar background",
      "default": "#080808"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text color",
      "default": "#777777"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#E84E4E"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#1e1e1e"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
{% endschema %}
