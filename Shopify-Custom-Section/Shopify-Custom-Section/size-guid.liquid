                  <td><span class="sg-cm">75–78</span><span class="sg-in" style="display:none">29.5–31</span></td>
                  <td><span class="sg-cm">168–173</span><span class="sg-in" style="display:none">66–68</span></td>
                </tr>
                <tr>
                  <td class="sg-sz">M</td>
                  <td><span class="sg-cm">93–98</span><span class="sg-in" style="display:none">36.5–38.5</span></td>
                  <td><span class="sg-cm">75–80</span><span class="sg-in" style="display:none">29.5–31.5</span></td>
                  <td><span class="sg-cm">97–102</span><span class="sg-in" style="display:none">38–40</span></td>
                  <td><span class="sg-cm">78–81</span><span class="sg-in" style="display:none">30.5–32</span></td>
                  <td><span class="sg-cm">173–178</span><span class="sg-in" style="display:none">68–70</span></td>
                </tr>
                <tr>
                  <td class="sg-sz">L</td>
                  <td><span class="sg-cm">99–104</span><span class="sg-in" style="display:none">39–41</span></td>
                  <td><span class="sg-cm">81–86</span><span class="sg-in" style="display:none">32–34</span></td>
                  <td><span class="sg-cm">103–108</span><span class="sg-in" style="display:none">40.5–42.5</span></td>
                  <td><span class="sg-cm">80–83</span><span class="sg-in" style="display:none">31.5–32.5</span></td>
                  <td><span class="sg-cm">178–183</span><span class="sg-in" style="display:none">70–72</span></td>
                </tr>
                <tr>
                  <td class="sg-sz">XL</td>
                  <td><span class="sg-cm">105–112</span><span class="sg-in" style="display:none">41.5–44</span></td>
                  <td><span class="sg-cm">87–94</span><span class="sg-in" style="display:none">34–37</span></td>
                  <td><span class="sg-cm">109–116</span><span class="sg-in" style="display:none">43–45.5</span></td>
                  <td><span class="sg-cm">82–85</span><span class="sg-in" style="display:none">32.5–33.5</span></td>
                  <td><span class="sg-cm">178–183</span><span class="sg-in" style="display:none">70–72</span></td>
                </tr>
                <tr>
                  <td class="sg-sz">XXL</td>
                  <td><span class="sg-cm">113–120</span><span class="sg-in" style="display:none">44.5–47</span></td>
                  <td><span class="sg-cm">95–102</span><span class="sg-in" style="display:none">37.5–40</span></td>
                  <td><span class="sg-cm">117–124</span><span class="sg-in" style="display:none">46–49</span></td>
                  <td><span class="sg-cm">84–87</span><span class="sg-in" style="display:none">33–34</span></td>
                  <td><span class="sg-cm">183–188</span><span class="sg-in" style="display:none">72–74</span></td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- How to measure tips -->
          <div class="sg-tips">
            <h4 class="sg-tips-title">How to Measure</h4>
            <ul class="sg-tips-list">
              <li><span class="sg-tip-dot" style="background:#E63946"></span><strong>Chest:</strong> Measure around the fullest part of your chest, keeping the tape horizontal under your arms.</li>
              <li><span class="sg-tip-dot" style="background:#2196F3"></span><strong>Waist:</strong> Measure around your natural waistline — the narrowest part of your torso.</li>
              <li><span class="sg-tip-dot" style="background:#4CAF50"></span><strong>Hip:</strong> Measure around the fullest part of your hips, approx. 20 cm below your waist.</li>
              <li><span class="sg-tip-dot" style="background:#FF9800"></span><strong>Inseam:</strong> Measure from your crotch to the floor along the inside of your leg.</li>
              <li><span class="sg-tip-dot" style="background:#9C27B0"></span><strong>Height:</strong> Stand straight without shoes. Measure from floor to top of your head.</li>
            </ul>
          </div>
        </div>

      </div>
    </div>

