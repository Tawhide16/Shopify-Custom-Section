<div class="sg-section" id="sg-{{ section.id }}">
  <div class="sg-wrap">

    <!-- Title -->
    <div class="sg-top">
      <h2 class="sg-title">{{ section.settings.title | default: 'Size Guide' }}</h2>
      {% if section.settings.subtitle != blank %}
        <p class="sg-subtitle">{{ section.settings.subtitle | default: 'Find your perfect fit.' }}</p>
      {% endif %}
    </div>

    <!-- Tabs + Unit Toggle Row -->
    <div class="sg-controls">
      <div class="sg-tabs">
        <button class="sg-tab active" onclick="sgTab(this,'sg-men-{{ section.id }}','{{ section.id }}')">{{ section.settings.tab_men | default: 'Men' }}</button>
        <button class="sg-tab" onclick="sgTab(this,'sg-women-{{ section.id }}','{{ section.id }}')">{{ section.settings.tab_women | default: 'Women' }}</button>
      </div>
      <div class="sg-unit-toggle">
        <button class="sg-unit active" onclick="sgUnit(this,'cm','{{ section.id }}')">CM</button>
        <button class="sg-unit" onclick="sgUnit(this,'in','{{ section.id }}')">INCHES</button>
      </div>
    </div>

    <!-- ===== MEN PANEL ===== -->
    <div class="sg-panel" id="sg-men-{{ section.id }}">
      <div class="sg-layout">

        <!-- LEFT: Measure Diagram Image -->
        <div class="sg-diagram">
          {% if section.settings.men_image %}
            <img src="{{ section.settings.men_image | img_url: '600x900', crop: 'top' }}" alt="Men size guide diagram" class="sg-diagram-img">
          {% else %}
            <!-- Built-in SVG diagram if no image uploaded -->
            <div class="sg-svg-diagram">
              <svg viewBox="0 0 220 480" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Body silhouette -->
                <ellipse cx="110" cy="52" rx="28" ry="30" stroke="#222" stroke-width="2.5" fill="#f0f0f0"/>
                <path d="M70 95 Q60 110 55 145 L50 200 Q48 215 55 220 L65 220 L68 260 L72 340 L82 340 L88 260 L90 240 L130 240 L132 260 L138 340 L148 340 L152 260 L155 220 L165 220 Q172 215 170 200 L165 145 Q160 110 150 95 Q130 82 110 82 Q90 82 70 95Z" fill="#f0f0f0" stroke="#222" stroke-width="2.5" stroke-linejoin="round"/>
                <!-- Legs -->
                <path d="M72 340 L68 420 L78 420 L88 350" fill="#f0f0f0" stroke="#222" stroke-width="2.5"/>
                <path d="M138 350 L148 420 L158 420 L152 340" fill="#f0f0f0" stroke="#222" stroke-width="2.5"/>

                <!-- CHEST line -->
                <line x1="55" y1="130" x2="165" y2="130" stroke="#E63946" stroke-width="1.8" stroke-dasharray="5 3"/>
                <circle cx="55" cy="130" r="3.5" fill="#E63946"/>
                <circle cx="165" cy="130" r="3.5" fill="#E63946"/>
                <text x="172" y="134" font-size="11" fill="#E63946" font-weight="700" font-family="Helvetica,Arial,sans-serif">CHEST</text>

                <!-- WAIST line -->
                <line x1="58" y1="175" x2="162" y2="175" stroke="#2196F3" stroke-width="1.8" stroke-dasharray="5 3"/>
                <circle cx="58" cy="175" r="3.5" fill="#2196F3"/>
                <circle cx="162" cy="175" r="3.5" fill="#2196F3"/>
                <text x="168" y="179" font-size="11" fill="#2196F3" font-weight="700" font-family="Helvetica,Arial,sans-serif">WAIST</text>

                <!-- HIP line -->
                <line x1="60" y1="220" x2="160" y2="220" stroke="#4CAF50" stroke-width="1.8" stroke-dasharray="5 3"/>
                <circle cx="60" cy="220" r="3.5" fill="#4CAF50"/>
                <circle cx="160" cy="220" r="3.5" fill="#4CAF50"/>
                <text x="166" y="224" font-size="11" fill="#4CAF50" font-weight="700" font-family="Helvetica,Arial,sans-serif">HIP</text>

                <!-- INSEAM line -->
                <line x1="110" y1="245" x2="110" y2="415" stroke="#FF9800" stroke-width="1.8" stroke-dasharray="5 3"/>
                <circle cx="110" cy="245" r="3.5" fill="#FF9800"/>
                <circle cx="110" cy="415" r="3.5" fill="#FF9800"/>
                <text x="115" y="340" font-size="11" fill="#FF9800" font-weight="700" font-family="Helvetica,Arial,sans-serif">INSEAM</text>

                <!-- HEIGHT arrow -->
                <line x1="30" y1="22" x2="30" y2="420" stroke="#9C27B0" stroke-width="1.8"/>
                <polygon points="30,18 27,26 33,26" fill="#9C27B0"/>
                <polygon points="30,424 27,416 33,416" fill="#9C27B0"/>
                <text x="4" y="225" font-size="10" fill="#9C27B0" font-weight="700" font-family="Helvetica,Arial,sans-serif" transform="rotate(-90,16,225)">HEIGHT</text>
              </svg>

              <!-- Legend -->
              <div class="sg-legend">
                <span class="sg-leg-item"><span class="sg-leg-dot" style="background:#E63946"></span>Chest</span>
                <span class="sg-leg-item"><span class="sg-leg-dot" style="background:#2196F3"></span>Waist</span>
                <span class="sg-leg-item"><span class="sg-leg-dot" style="background:#4CAF50"></span>Hip</span>
                <span class="sg-leg-item"><span class="sg-leg-dot" style="background:#FF9800"></span>Inseam</span>
                <span class="sg-leg-item"><span class="sg-leg-dot" style="background:#9C27B0"></span>Height</span>
              </div>
            </div>
          {% endif %}
        </div>

        <!-- RIGHT: Table -->
        <div class="sg-table-side">
          <div class="sg-table-scroll">
            <table class="sg-table">
              <thead>
                <tr>
                  <th>Size</th>
                  <th><span class="sg-cm">Chest<br><small>cm</small></span><span class="sg-in" style="display:none">Chest<br><small>in</small></span></th>
                  <th><span class="sg-cm">Waist<br><small>cm</small></span><span class="sg-in" style="display:none">Waist<br><small>in</small></span></th>
                  <th><span class="sg-cm">Hip<br><small>cm</small></span><span class="sg-in" style="display:none">Hip<br><small>in</small></span></th>
                  <th><span class="sg-cm">Inseam<br><small>cm</small></span><span class="sg-in" style="display:none">Inseam<br><small>in</small></span></th>
                  <th><span class="sg-cm">Height<br><small>cm</small></span><span class="sg-in" style="display:none">Height<br><small>in</small></span></th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="sg-sz">XXS</td>
