                  <td><span class="sg-cm">88–91</span><span class="sg-in" style="display:none">34.5–36</span></td>
                  <td><span class="sg-cm">73–76</span><span class="sg-in" style="display:none">29–30</span></td>
                  <td><span class="sg-cm">163–168</span><span class="sg-in" style="display:none">64–66</span></td>
