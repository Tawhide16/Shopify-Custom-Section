                  <td><span class="sg-cm">62–65</span><span class="sg-in" style="display:none">24.5–25.5</span></td>
                  <td><span class="sg-cm">84–87</span><span class="sg-in" style="display:none">33–34</span></td>
                  <td><span class="sg-cm">71–74</span><span class="sg-in" style="display:none">28–29</span></td>
                  <td><span class="sg-cm">163–168</span><span class="sg-in" style="display:none">64–66</span></td>
                </tr>
                <tr>
                  <td class="sg-sz">XS</td>
