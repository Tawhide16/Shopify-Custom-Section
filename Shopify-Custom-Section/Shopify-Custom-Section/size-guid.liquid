      {{ section.settings.fit_note }}
    </div>
    {% endif %}

  </div>
</div>

<style>
.sg-section {
  width: 100%;
  background: {{ section.settings.bg_color | default: '#ffffff' }};
  padding: 56px 0 64px;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
}
.sg-wrap {
  max-width: {{ section.settings.max_width | default: 1400 }}px;
  margin: 0 auto;
  padding: 0 24px;
}

/* Top */
.sg-top { text-align: center; margin-bottom: 36px; }
.sg-title { font-size: 26px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; color: #111; margin: 0 0 8px; }
.sg-subtitle { font-size: 14px; color: #666; margin: 0; }

/* Controls Row */
.sg-controls { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0; flex-wrap: wrap; gap: 12px; }

/* Tabs */
.sg-tabs { display: flex; border-bottom: 2px solid #eee; }
.sg-tab { padding: 11px 28px; font-size: 13px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; border: none; background: none; color: #aaa; cursor: pointer; position: relative; transition: color .2s; }
.sg-tab::after { content: ''; position: absolute; bottom: -2px; left: 0; right: 0; height: 2px; background: #111; transform: scaleX(0); transition: transform .22s ease; }
.sg-tab.active { color: #111; }
.sg-tab.active::after { transform: scaleX(1); }

/* Unit Toggle */
.sg-unit-toggle { display: flex; }
.sg-unit { padding: 7px 18px; font-size: 11px; font-weight: 800; letter-spacing: .08em; border: 1.5px solid #ddd; background: #fff; color: #888; cursor: pointer; transition: all .2s; }
.sg-unit:first-child { border-radius: 4px 0 0 4px; }
.sg-unit:last-child  { border-radius: 0 4px 4px 0; border-left: none; }
.sg-unit.active { background: #111; border-color: #111; color: #fff; }

/* Panel */
.sg-panel { padding-top: 32px; }

/* Two-col layout */
.sg-layout { display: grid; grid-template-columns: 280px 1fr; gap: 48px; align-items: start; }
@media(max-width: 900px) { .sg-layout { grid-template-columns: 1fr; } }

/* Diagram */
.sg-diagram { position: sticky; top: 20px; }
.sg-diagram-img { width: 100%; border-radius: 6px; display: block; }
.sg-svg-diagram { background: #fafafa; border: 1.5px solid #eee; border-radius: 8px; padding: 20px 10px 16px; }
.sg-svg-diagram svg { width: 100%; height: auto; display: block; }

.sg-legend { display: flex; flex-wrap: wrap; gap: 8px 14px; margin-top: 16px; justify-content: center; }
.sg-leg-item { display: flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; color: #444; letter-spacing: .03em; }
.sg-leg-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

/* Table */
.sg-table-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; border: 1.5px solid #eee; border-radius: 6px; }
.sg-table { width: 100%; border-collapse: collapse; min-width: 480px; font-size: 13px; }
.sg-table thead tr { background: #111; }
.sg-table thead th { padding: 13px 14px; font-weight: 700; letter-spacing: .04em; text-align: center; color: #fff; font-size: 11px; text-transform: uppercase; white-space: nowrap; }
.sg-table thead th:first-child { text-align: left; }
.sg-table thead th small { font-weight: 400; opacity: .7; font-size: 10px; letter-spacing: 0; }
.sg-table tbody tr { border-bottom: 1px solid #f0f0f0; transition: background .15s; }
.sg-table tbody tr:last-child { border-bottom: none; }
.sg-table tbody tr:hover { background: #f7f7f7; }
.sg-table tbody td { padding: 13px 14px; text-align: center; color: #444; font-size: 13px; }
.sg-sz { font-weight: 800; color: #111; text-align: left; letter-spacing: .04em; }

/* Tips */
.sg-tips { margin-top: 28px; padding: 20px 24px; background: #f8f8f8; border-radius: 6px; }
.sg-tips-title { font-size: 12px; font-weight: 800; letter-spacing: .07em; text-transform: uppercase; color: #111; margin: 0 0 14px; }
.sg-tips-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
.sg-tips-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 12px; color: #555; line-height: 1.55; }
.sg-tip-dot { width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }

/* Fit note */
.sg-fitnote { display: flex; align-items: flex-start; gap: 10px; margin-top: 32px; padding: 14px 18px; background: #f5f5f5; border-left: 3px solid #111; font-size: 13px; color: #444; line-height: 1.6; border-radius: 0 4px 4px 0; }
.sg-fitnote svg { flex-shrink: 0; margin-top: 2px; }
</style>

<script>
function sgTab(btn, panelId, secId) {
  var sec = document.getElementById('sg-' + secId);
  sec.querySelectorAll('.sg-tab').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  sec.querySelectorAll('.sg-panel').forEach(function(p) { p.style.display = 'none'; });
  var panel = document.getElementById(panelId);
  if (panel) panel.style.display = 'block';
}

function sgUnit(btn, unit, secId) {
  var sec = document.getElementById('sg-' + secId);
  sec.querySelectorAll('.sg-unit').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  sec.querySelectorAll('.sg-cm').forEach(function(el) { el.style.display = unit === 'cm' ? '' : 'none'; });
  sec.querySelectorAll('.sg-in').forEach(function(el) { el.style.display = unit === 'in' ? '' : 'none'; });
}
</script>

{% schema %}
{
  "name": "Size Guide",
  "tag": "section",
  "class": "section-sg",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Size Guide"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Find your perfect fit with our size guide below."
    },
    {
      "type": "text",
      "id": "tab_men",
      "label": "Men Tab Label",
      "default": "Men"
    },
    {
      "type": "text",
      "id": "tab_women",
      "label": "Women Tab Label",
      "default": "Women"
    },
    {
      "type": "image_picker",
      "id": "men_image",
      "label": "Men Diagram Image (optional)"
    },
    {
      "type": "image_picker",
      "id": "women_image",
      "label": "Women Diagram Image (optional)"
    },
    {
      "type": "textarea",
      "id": "fit_note",
      "label": "Fit Note",
      "default": "If you are between sizes, we recommend sizing up for a more relaxed fit or sizing down for a tighter fit."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width (px)",
      "min": 800,
      "max": 1800,
      "step": 50,
      "default": 1400
    }
  ],
  "presets": [
    {
      "name": "Size Guide"
    }
  ]
}
{% endschema %}
