{% comment %}
  Hero Banner Section — Spring Campaign
  Supports: background video (mp4) or fallback image
  Upload to: Sections > hero-banner.liquid
{% endcomment %}

<style>
  .hero-banner {
    position: relative;
    width: 100%;
    height: {{ section.settings.section_height }}vh;
    min-height: 500px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  /* ── Media Layer ── */
  .hero-banner__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-banner__video,
  .hero-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.focal_point }};
    display: block;
  }

  /* ── Overlay ── */
  .hero-banner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }}) 0%,
      rgba(0, 0, 0, 0) 55%
    );
  }

  /* ── Content ── */
  .hero-banner__content {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 0 20px 60px;
    width: 100%;
    max-width: 600px;
    animation: heroFadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-banner__eyebrow {
    font-family: {{ section.settings.heading_font }}, 'Helvetica Neue', Helvetica, sans-serif;
    font-size: clamp(18px, 2.2vw, 26px);
    font-weight: 500;
    letter-spacing: 0.18em;
    color: #ffffff;
    margin: 0 0 10px;
    text-transform: uppercase;
  }

  .hero-banner__subheading {
    font-family: {{ section.settings.body_font }}, Georgia, serif;
    font-size: clamp(14px, 1.5vw, 18px);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.92);
    margin: 0 0 28px;
  }

  .hero-banner__btn {
    display: inline-block;
    padding: 15px 48px;
    background-color: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    font-family: {{ section.settings.heading_font }}, 'Helvetica Neue', Helvetica, sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.25s ease, color 0.25s ease, transform 0.2s ease;
  }

  .hero-banner__btn:hover {
    background-color: {{ section.settings.button_hover_bg }};
    color: {{ section.settings.button_hover_text }};
    transform: translateY(-1px);
  }

  /* ── Mobile ── */
  @media (max-width: 749px) {
    .hero-banner {
      height: {{ section.settings.mobile_height }}vh;
      min-height: 400px;
    }

    .hero-banner__content {
      padding-bottom: 44px;
    }
  }
</style>

<section
  class="hero-banner"
  id="hero-banner-{{ section.id }}"
  aria-label="{{ section.settings.heading | escape }}"
>

  <!-- ── Media ── -->
  <div class="hero-banner__media">

    {%- comment -%} Priority: 1) Uploaded video  2) Video URL  3) Image  4) Placeholder {%- endcomment -%}

    {%- if section.settings.video != blank -%}
      {{-
        section.settings.video
        | video_tag:
          class: 'hero-banner__video',
          autoplay: true,
          loop: true,
          muted: true,
          playsinline: true,
          poster: section.settings.image | image_url: width: 1920
      -}}

    {%- elsif section.settings.video_url != blank -%}
      <video
        class="hero-banner__video"
        autoplay
        muted
        loop
        playsinline
        {% if section.settings.image != blank %}
          poster="{{ section.settings.image | image_url: width: 1920 }}"
        {% endif %}
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>

    {%- elsif section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1920
        | image_tag:
          class: 'hero-banner__image',
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 1780, 1920',
          sizes: '100vw',
          alt: section.settings.image.alt | escape
      }}

    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-banner__image placeholder-svg' }}
    {%- endif -%}

  </div>

  <!-- ── Overlay ── -->
  <div class="hero-banner__overlay" aria-hidden="true"></div>

  <!-- ── Content ── -->
  <div class="hero-banner__content">

    {%- if section.settings.heading != blank -%}
      <p class="hero-banner__eyebrow">{{ section.settings.heading }}</p>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-banner__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <a
        class="hero-banner__btn"
        href="{{ section.settings.button_link }}"
        {% if section.settings.button_new_tab %}target="_blank" rel="noopener"{% endif %}
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}

  </div>

</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero-banner",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image",
      "info": "Used as fallback when no video is set, or as the video poster frame. Recommended: 1920×1080px or wider."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background video (Upload)",
      "info": "Customizer থেকে সরাসরি video upload করুন — সবচেয়ে সহজ পদ্ধতি।"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "অথবা Video URL দিন (.mp4)",
      "info": "Shopify Admin → Settings → Files থেকে video upload করে URL copy করুন। Upload করা video থাকলে এটা কাজ করবে না।"
    },
    {
      "type": "select",
      "id": "focal_point",
      "label": "Media focal point",
      "options": [
        { "value": "top center",    "label": "Top" },
        { "value": "center center", "label": "Centre" },
        { "value": "bottom center", "label": "Bottom" },
        { "value": "left center",   "label": "Left" },
        { "value": "right center",  "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Gradient overlay strength",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 45
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SPRING '26"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our new season is now live."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "button_new_tab",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
      "label": "Button hover background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_text",
      "label": "Button hover text",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "text",
      "id": "heading_font",
      "label": "Heading font family",
      "default": "'Helvetica Neue'",
      "info": "Enter any web-safe or Google Font name loaded in your theme."
    },
    {
      "type": "text",
      "id": "body_font",
      "label": "Body font family",
      "default": "Georgia",
      "info": "Enter any web-safe or Google Font name loaded in your theme."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Desktop height (vh)",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 85
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height (vh)",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 75
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
