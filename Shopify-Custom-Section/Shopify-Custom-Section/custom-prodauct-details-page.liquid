{% comment %}
=======================================================
  JOOVV-STYLE PRODUCT PAGE
  ✅ Left: 2-column masonry-style image grid
  ✅ Right: Sticky info — title, price, affirm, desc,
           variant pickers, ATC, BUY NOW, trust badges,
           collapsible tabs
  📁 File: main-product.liquid (replace existing)
  📂 Upload to: Sections folder
=======================================================
{% endcomment %}

{{ 'product.css' | asset_url | stylesheet_tag }}
{% if section.settings.show_zoom_button %}
  {{ 'photoswipe.css' | asset_url | stylesheet_tag }}
  {{ 'component-photoswipe.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- if product.quantity_price_breaks_configured? -%}
  {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'show-more.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<style>
/* ════════════════════════════════════════
   JOOVV PRODUCT PAGE LAYOUT
════════════════════════════════════════ */
.jp-page {
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: {{ section.settings.padding_top }}px {{ section.settings.side_padding }}px {{ section.settings.padding_bottom }}px;
  display: grid;
  grid-template-columns: minmax(0, 1fr) {{ section.settings.info_width }}px;
  gap: {{ section.settings.col_gap }}px;
  align-items: start;
}

/* ════════════════════════════════════════
   LEFT — Image Grid (2 columns)
════════════════════════════════════════ */
.jp-images {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: {{ section.settings.img_gap }}px;
}

.jp-img-item {
  border-radius: {{ section.settings.img_radius }}px;
  overflow: hidden;
  background: #f5f5f5;
  cursor: zoom-in;
}

.jp-img-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}
.jp-img-item:hover img { transform: scale(1.03); }

.jp-img-item--featured {
  grid-column: 1 / -1;
}
.jp-img-item--tall {
  aspect-ratio: 3/4;
}
.jp-img-item--square {
  aspect-ratio: 1/1;
}

/* ════════════════════════════════════════
   RIGHT — Sticky Info Panel
════════════════════════════════════════ */
.jp-info {
  position: sticky;
  top: {{ section.settings.sticky_top }}px;
}

/* ── Title ── */
.jp-title {
  font-size: clamp(24px, 2.5vw, 38px);
  font-weight: 800;
  color: {{ section.settings.title_color }};
  margin: 0 0 16px;
  letter-spacing: -0.02em;
  line-height: 1.1;
}

/* ── Price ── */
.jp-price-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}
.jp-price {
  font-size: 20px;
  font-weight: 600;
  color: {{ section.settings.price_color }};
}
.jp-price-compare {
  font-size: 16px;
  color: #999;
  text-decoration: line-through;
}
.jp-price-help {
  width: 18px;
  height: 18px;
  border: 1.5px solid #aaa;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  color: #777;
  cursor: help;
  flex-shrink: 0;
}

/* ── Affirm / Financing text ── */
.jp-affirm {
  font-size: 12px;
  color: #555;
  margin-bottom: 16px;
  line-height: 1.5;
}
.jp-affirm a {
  color: {{ section.settings.link_color }};
  text-decoration: underline;
}

/* ── Description ── */
.jp-desc {
  font-size: 13.5px;
  line-height: 1.75;
  color: {{ section.settings.desc_color }};
  margin-bottom: 24px;
}

/* ── Variant Label Row ── */
.jp-variant-group {
  margin-bottom: 18px;
}
.jp-variant-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}
.jp-variant-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: {{ section.settings.label_color }};
}
.jp-size-guide {
  font-size: 11px;
  color: {{ section.settings.link_color }};
  text-decoration: underline;
  cursor: pointer;
  background: none;
  border: none;
  padding: 0;
  font-family: inherit;
}

/* ── Variant Buttons ── */
.jp-variant-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.jp-variant-btn {
  padding: 10px 20px;
  border: 1.5px solid #ddd;
  background: #fff;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  font-family: inherit;
  transition: border-color 0.2s, background 0.2s;
  border-radius: {{ section.settings.btn_radius }}px;
}
.jp-variant-btn:hover {
  border-color: #111;
}
.jp-variant-btn.is-selected {
  border-color: #111111;
  background: #fff;
  color: #111111;
}
.jp-variant-btn.is-unavailable {
  opacity: 0.4;
  cursor: not-allowed;
  text-decoration: line-through;
}

/* ════════════════════════════════════════
   SUGGESTION CARDS
════════════════════════════════════════ */
.jp-suggest {
  margin-bottom: 20px;
}
.jp-suggest-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #888;
  margin-bottom: 10px;
}
.jp-suggest-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.jp-suggest-card {
  border: 1.5px solid #e8e8e8;
  border-radius: 8px;
  overflow: hidden;
  background: #fff;
  transition: border-color 0.2s, box-shadow 0.2s;
  cursor: pointer;
}
.jp-suggest-card:hover {
  border-color: #111;
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
}
.jp-suggest-card.is-added {
  border-color: #111;
  background: #fafafa;
}
.jp-suggest-card__img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  display: block;
  background: #f5f5f5;
}
.jp-suggest-card__img-placeholder {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: linear-gradient(135deg, #f0f0f0, #e4e4e4);
  display: flex;
  align-items: center;
  justify-content: center;
}
.jp-suggest-card__img-placeholder svg {
  width: 36px;
  height: 36px;
  opacity: 0.3;
}
.jp-suggest-card__body {
  padding: 10px 10px 12px;
}
.jp-suggest-card__title {
  font-size: 11.5px;
  font-weight: 700;
  color: #111;
  margin: 0 0 3px;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.jp-suggest-card__price {
  font-size: 11px;
  color: #555;
  margin: 0 0 10px;
}
.jp-suggest-card__btn {
  width: 100%;
  padding: 8px 10px;
  background: #fff;
  color: #111;
  border: 1.5px solid #111;
  font-size: 9.5px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  font-family: inherit;
  border-radius: 4px;
  transition: background 0.2s, color 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
}
.jp-suggest-card__btn:hover {
  background: #111;
  color: #fff;
}
.jp-suggest-card.is-added .jp-suggest-card__btn {
  background: #111;
  color: #fff;
}
.jp-suggest-card__btn-icon {
  font-size: 13px;
  line-height: 1;
  transition: transform 0.2s;
}
.jp-suggest-card.is-added .jp-suggest-card__btn-icon {
  content: '✓';
}

/* ── ATC & Buy Now Button Wrapper ── */
.jp-atc-wrap {
  margin-bottom: 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

/* ── Add to Cart Button — BLACK ── */
.jp-atc-btn {
  width: 100%;
  padding: 16px 24px;
  background: #111111;
  color: #ffffff;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  font-family: inherit;
  border-radius: {{ section.settings.btn_radius }}px;
  transition: opacity 0.2s;
}
.jp-atc-btn:hover { opacity: 0.82; }
.jp-atc-btn:disabled { opacity: 0.45; cursor: not-allowed; }

/* ── Buy Now Button — Outlined ── */
.jp-buy-now-btn {
  width: 100%;
  padding: 15px 24px;
  background: #ffffff;
  color: #111111;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  border: 2px solid #111111;
  cursor: pointer;
  font-family: inherit;
  border-radius: {{ section.settings.btn_radius }}px;
  transition: background 0.2s, color 0.2s;
  text-decoration: none;
  display: block;
  text-align: center;
  box-sizing: border-box;
}
.jp-buy-now-btn:hover {
  background: #111111;
  color: #ffffff;
}
.jp-buy-now-btn:disabled { opacity: 0.45; cursor: not-allowed; }

/* ── Shipping notice ── */
.jp-shipping-notice {
  text-align: center;
  font-size: 11.5px;
  color: {{ section.settings.link_color }};
  text-decoration: underline;
  margin-bottom: 24px;
  cursor: pointer;
}

/* ── Trust Badges ── */
.jp-trust {
  display: flex;
  justify-content: center;
  gap: 24px;
  padding: 20px 0;
  border-top: 1px solid #eee;
  border-bottom: 1px solid #eee;
  margin-bottom: 24px;
}
.jp-trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  text-align: center;
}
.jp-trust-item svg,
.jp-trust-item img {
  width: 44px;
  height: 44px;
  object-fit: contain;
}
.jp-trust-item span {
  font-size: 10px;
  font-weight: 600;
  color: #444;
  letter-spacing: 0.03em;
  line-height: 1.3;
}

/* ── Collapsible Tabs ── */
.jp-tabs {
  border-top: 1px solid #e8e8e8;
}
.jp-tab {
  border-bottom: 1px solid #e8e8e8;
}
.jp-tab-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 0;
  background: none;
  border: none;
  cursor: pointer;
  font-family: inherit;
  text-align: left;
}
.jp-tab-btn-text {
  font-size: 14px;
  font-weight: 600;
  color: {{ section.settings.title_color }};
}
.jp-tab-icon {
  font-size: 20px;
  font-weight: 300;
  color: #555;
  transition: transform 0.25s ease;
  flex-shrink: 0;
  line-height: 1;
}
.jp-tab.is-open .jp-tab-icon {
  transform: rotate(45deg);
}
.jp-tab-content {
  overflow: hidden;
  max-height: 0;
  opacity: 0;
  transition: max-height 0.38s ease, opacity 0.3s ease;
}
.jp-tab.is-open .jp-tab-content {
  max-height: 1000px;
  opacity: 1;
}
.jp-tab-content-inner {
  padding: 0 0 18px;
  font-size: 13px;
  line-height: 1.75;
  color: {{ section.settings.desc_color }};
}

/* ── Reviews stars in tab ── */
.jp-tab-stars {
  display: flex;
  align-items: center;
  gap: 6px;
}
.jp-stars {
  color: {{ section.settings.star_color }};
  font-size: 16px;
  letter-spacing: 1px;
}

/* ════════════════════════════════════════
   RESPONSIVE
════════════════════════════════════════ */
@media (max-width: 1023px) {
  .jp-page {
    grid-template-columns: 1fr;
    padding: 20px 16px 40px;
  }

  /* Mobile: flexbox column with custom order */
  .jp-info {
    position: static;
    display: flex;
    flex-direction: column;
  }

  .jp-title           { order: 1; }
  .jp-price-row       { order: 2; }
  .jp-variant-group   { order: 3; }
  .jp-affirm          { order: 4; }
  .jp-desc            { order: 5; }
  .jp-suggest         { order: 6; }
  .jp-atc-wrap        { order: 7; }
  .jp-shipping-notice { order: 8; }
  .jp-trust           { order: 9; }
  .jp-tabs            { order: 10; }
}

@media (max-width: 479px) {
  .jp-images { grid-template-columns: 1fr 1fr; gap: 8px; }
}
</style>

{%- liquid
  assign container = section.settings.container
  assign layout = section.settings.layout
  if container == 'w-full'
    assign container = 'container-full'
  endif
  assign first_3d_model = product.media | where: 'media_type', 'model' | first
  assign tab_blocks = section.blocks | where: 'type', 'collapsible_tab'
  assign trust_blocks = section.blocks | where: 'type', 'trust_item'
  assign variant_blocks = section.blocks | where: 'type', 'variant_group'
-%}

<div class="jp-page">

  {%- comment -%} ══ LEFT — IMAGE GRID ══ {%- endcomment -%}
  <div class="jp-images">
    {%- for media in product.media -%}
      {%- assign media_class = 'jp-img-item' -%}
      <div class="{{ media_class }}">
        {%- if media.media_type == 'image' -%}
          {%- assign img_src = media | image_url: width: 900 -%}
          <img
            src="{{ img_src }}"
            alt="{{ media.alt | default: product.title }}"
            {% if forloop.index <= 2 %}loading="eager"{% else %}loading="lazy"{% endif %}
          >
        {%- elsif media.media_type == 'video' -%}
          <video autoplay muted loop playsinline style="width:100%;height:100%;object-fit:cover;">
            {%- for source in media.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        {%- endif -%}
      </div>
    {%- else -%}
      <div class="jp-img-item" style="background:#f0f0f0;aspect-ratio:1/1;"></div>
    {%- endfor -%}
  </div>

  {%- comment -%} ══ RIGHT — INFO PANEL ══ {%- endcomment -%}
  <div class="jp-info">

    {%- comment -%} Title {%- endcomment -%}
    <h1 class="jp-title">{{ product.title }}</h1>

    {%- comment -%} Price {%- endcomment -%}
    <div class="jp-price-row">
      <span class="jp-price">
        {{ product.selected_or_first_available_variant.price | money }}
      </span>
      {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
        <span class="jp-price-compare">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
      {%- endif -%}
      <span class="jp-price-help" title="Price info">?</span>
    </div>

    {%- comment -%} Variant Pickers — placed here so mobile order:3 puts them right after price {%- endcomment -%}
    {%- unless product.has_only_default_variant -%}
      {%- for option in product.options_with_values -%}
        <div class="jp-variant-group">
          <div class="jp-variant-header">
            <span class="jp-variant-label">{{ option.name | upcase }}</span>
            {%- if option.name == 'Size' or option.name == 'Kit' -%}
              <button class="jp-size-guide" type="button">Size Guide</button>
            {%- endif -%}
          </div>
          <div class="jp-variant-btns">
            {%- for value in option.values -%}
              {%- assign is_selected = false -%}
              {%- if product.selected_or_first_available_variant.options contains value -%}
                {%- assign is_selected = true -%}
              {%- endif -%}
              <button
                class="jp-variant-btn{% if is_selected %} is-selected{% endif %}"
                type="button"
                data-option-position="{{ option.position }}"
                data-option-value="{{ value | escape }}"
              >
                {{ value }}
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    {%- endunless -%}

    {%- comment -%} Affirm / Financing {%- endcomment -%}
    {%- if section.settings.affirm_text != blank -%}
      <p class="jp-affirm">{{ section.settings.affirm_text }}</p>
    {%- endif -%}

    {%- comment -%} Short Description {%- endcomment -%}
    {%- if product.description != blank -%}
      <div class="jp-desc">{{ product.description | strip_html | truncatewords: 60 }}</div>
    {%- endif -%}

    {%- comment -%} ══ SUGGESTION CARDS — Metafield Dynamic ══ {%- endcomment -%}
    {%- liquid
      assign s1 = product.metafields.custom.suggestion_1.value
      assign s2 = product.metafields.custom.suggestion_2.value
      assign has_suggestions = false
      if s1 != blank or s2 != blank
        assign has_suggestions = true
      endif
    -%}
    {%- if has_suggestions -%}
      <div class="jp-suggest">
        <p class="jp-suggest-label">{{ section.settings.suggest_label | default: 'You May Also Need' }}</p>
        <div class="jp-suggest-cards">

          {%- comment -%} — Suggestion 1 — {%- endcomment -%}
          {%- if s1 != blank -%}
            {%- assign sv1 = s1.selected_or_first_available_variant -%}
            <div class="jp-suggest-card" data-variant-id="{{ sv1.id }}" data-product-id="{{ s1.id }}">
              {%- if s1.featured_image -%}
                <img class="jp-suggest-card__img" src="{{ s1.featured_image | image_url: width: 400 }}" alt="{{ s1.title }}" loading="lazy">
              {%- else -%}
                <div class="jp-suggest-card__img-placeholder">
                  <svg viewBox="0 0 44 44" fill="none"><rect x="6" y="6" width="32" height="32" rx="4" stroke="#ccc" stroke-width="2"/><circle cx="15" cy="15" r="4" stroke="#ccc" stroke-width="1.5"/><polyline points="6,30 16,20 24,28 30,22 38,32" stroke="#ccc" stroke-width="1.5" fill="none"/></svg>
                </div>
              {%- endif -%}
              <div class="jp-suggest-card__body">
                <p class="jp-suggest-card__title">{{ s1.title }}</p>
                <p class="jp-suggest-card__price">{{ sv1.price | money }}</p>
                <button class="jp-suggest-card__btn" type="button" data-suggest-atc="{{ sv1.id }}">
                  <span class="jp-suggest-card__btn-icon">+</span>
                  <span class="jp-suggest-card__btn-text">Add Product</span>
                </button>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} — Suggestion 2 — {%- endcomment -%}
          {%- if s2 != blank -%}
            {%- assign sv2 = s2.selected_or_first_available_variant -%}
            <div class="jp-suggest-card" data-variant-id="{{ sv2.id }}" data-product-id="{{ s2.id }}">
              {%- if s2.featured_image -%}
                <img class="jp-suggest-card__img" src="{{ s2.featured_image | image_url: width: 400 }}" alt="{{ s2.title }}" loading="lazy">
              {%- else -%}
                <div class="jp-suggest-card__img-placeholder">
                  <svg viewBox="0 0 44 44" fill="none"><rect x="6" y="6" width="32" height="32" rx="4" stroke="#ccc" stroke-width="2"/><circle cx="15" cy="15" r="4" stroke="#ccc" stroke-width="1.5"/><polyline points="6,30 16,20 24,28 30,22 38,32" stroke="#ccc" stroke-width="1.5" fill="none"/></svg>
                </div>
              {%- endif -%}
              <div class="jp-suggest-card__body">
                <p class="jp-suggest-card__title">{{ s2.title }}</p>
                <p class="jp-suggest-card__price">{{ sv2.price | money }}</p>
                <button class="jp-suggest-card__btn" type="button" data-suggest-atc="{{ sv2.id }}">
                  <span class="jp-suggest-card__btn-icon">+</span>
                  <span class="jp-suggest-card__btn-text">Add Product</span>
                </button>
              </div>
            </div>
          {%- endif -%}

        </div>
      </div>
    {%- endif -%}

    {%- comment -%} Add to Cart + Buy Now Buttons {%- endcomment -%}
    <div class="jp-atc-wrap">
      {%- form 'product', product, id: 'jp-product-form', class: 'jp-form' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        {%- comment -%} ADD TO CART — Black background, white text {%- endcomment -%}
        <button
          type="submit"
          class="jp-atc-btn"
          {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
        >
          {%- if product.selected_or_first_available_variant.available -%}
            {{ section.settings.atc_text | default: 'ADD TO CART' }}
          {%- else -%}
            SOLD OUT
          {%- endif -%}
        </button>
      {%- endform -%}

      {%- comment -%} BUY NOW — Outlined button, redirects to checkout {%- endcomment -%}
      {%- if product.selected_or_first_available_variant.available -%}
        <a
          href="/cart/{{ product.selected_or_first_available_variant.id }}:1?checkout"
          class="jp-buy-now-btn"
          id="jp-buy-now"
        >
          {{ section.settings.buy_now_text | default: 'BUY NOW' }}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Shipping Notice {%- endcomment -%}
    {%- if section.settings.shipping_notice != blank -%}
      <p class="jp-shipping-notice">{{ section.settings.shipping_notice }}</p>
    {%- endif -%}

    {%- comment -%} Trust Badges {%- endcomment -%}
    <div class="jp-trust">
      {%- for block in trust_blocks -%}
        <div class="jp-trust-item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon_image != blank -%}
            {%- assign trust_src = block.settings.icon_image | image_url: width: 88 -%}
            <img src="{{ trust_src }}" alt="{{ block.settings.label }}" width="44" height="44" loading="lazy">
          {%- else -%}
            {%- case block.settings.icon_type -%}
              {%- when 'medical' -%}
              <svg viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 12L22 6L36 12V24C36 31 29 37 22 40C15 37 8 31 8 24V12Z" stroke="{{ section.settings.badge_icon_color }}" stroke-width="2" fill="none"/>
                <line x1="22" y1="16" x2="22" y2="28" stroke="{{ section.settings.badge_icon_color }}" stroke-width="2.5" stroke-linecap="round"/>
                <line x1="16" y1="22" x2="28" y2="22" stroke="{{ section.settings.badge_icon_color }}" stroke-width="2.5" stroke-linecap="round"/>
              </svg>
              {%- when 'warranty' -%}
              <svg viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
