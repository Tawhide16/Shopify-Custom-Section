<script>
(function () {
  /* ── Collapsible Tabs ── */
  var tabs = document.querySelectorAll('.jp-tab');
  tabs.forEach(function (tab) {
    var btn = tab.querySelector('.jp-tab-btn');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var isOpen = tab.classList.contains('is-open');
      tabs.forEach(function (t) { t.classList.remove('is-open'); t.querySelector('.jp-tab-btn') && t.querySelector('.jp-tab-btn').setAttribute('aria-expanded','false'); });
      if (!isOpen) {
        tab.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  /* ── Suggestion Card: Add Product ── */
  document.querySelectorAll('.jp-suggest-card__btn').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.stopPropagation();
      var variantId = btn.dataset.suggestAtc;
      if (!variantId) return;

      var card = btn.closest('.jp-suggest-card');
      var btnText = btn.querySelector('.jp-suggest-card__btn-text');
      var btnIcon = btn.querySelector('.jp-suggest-card__btn-icon');

      /* Optimistic UI */
      btn.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
      .then(function (res) { return res.json(); })
      .then(function (data) {
        if (data.id) {
          card.classList.add('is-added');
          if (btnIcon) btnIcon.textContent = '✓';
          if (btnText) btnText.textContent = 'Added!';
          /* Update cart count bubble if present */
          var countEl = document.querySelector('.cart-count-bubble, .cart-item-count, [data-cart-count]');
          if (countEl) {
            var current = parseInt(countEl.textContent) || 0;
            countEl.textContent = current + 1;
          }
          /* Reset after 3s */
          setTimeout(function () {
            card.classList.remove('is-added');
            if (btnIcon) btnIcon.textContent = '+';
            if (btnText) btnText.textContent = 'Add Product';
            btn.disabled = false;
          }, 3000);
        } else {
          btn.disabled = false;
        }
      })
      .catch(function () { btn.disabled = false; });
    });
  });

  /* ── Variant Picker ── */
  var variantBtns = document.querySelectorAll('.jp-variant-btn');
  variantBtns.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var pos = btn.dataset.optionPosition;
      document.querySelectorAll('.jp-variant-btn[data-option-position="' + pos + '"]').forEach(function (b) {
        b.classList.remove('is-selected');
      });
      btn.classList.add('is-selected');

      var selectedOptions = [];
      [1, 2, 3].forEach(function (p) {
        var sel = document.querySelector('.jp-variant-btn[data-option-position="' + p + '"].is-selected');
        if (sel) selectedOptions.push(sel.dataset.optionValue);
      });

      var variantData = {{ product.variants | json }};
      var matched = variantData.find(function (v) {
        return v.options.every(function (opt, i) {
          return !selectedOptions[i] || opt === selectedOptions[i];
        });
      });

      if (matched) {
        /* Update hidden input */
        var input = document.querySelector('#jp-product-form input[name="id"]');
        if (input) input.value = matched.id;

        /* Update price */
        var priceEl = document.querySelector('.jp-price');
        if (priceEl) {
          priceEl.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: '{{ cart.currency.iso_code }}' }).format(matched.price / 100);
        }

        /* Update ATC button */
        var atcBtn = document.querySelector('.jp-atc-btn');
        if (atcBtn) {
          atcBtn.disabled = !matched.available;
          atcBtn.textContent = matched.available ? '{{ section.settings.atc_text | default: "ADD TO CART" }}' : 'SOLD OUT';
        }

        /* Update Buy Now link */
        var buyNowBtn = document.querySelector('#jp-buy-now');
        if (buyNowBtn) {
          buyNowBtn.href = '/cart/' + matched.id + ':1?checkout';
          buyNowBtn.style.display = matched.available ? 'block' : 'none';
        }
      }
    });
  });
})();
</script>

